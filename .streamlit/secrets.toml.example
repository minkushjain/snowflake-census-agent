# Template for local credentials.
# Copy this file to .streamlit/secrets.toml and fill in your real values.
# secrets.toml is gitignored and must never be committed.

# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-..."

# Snowflake connection — must have SELECT access on the census dataset
[connections.snowflake]
account = "YOUR-ACCOUNT-IDENTIFIER"   # e.g. xy12345.us-east-1 (from your Snowflake login URL)
user = "YOUR_SNOWFLAKE_USER"
password = "YOUR_SNOWFLAKE_PASSWORD"
role = "ACCOUNTADMIN"
warehouse = "COMPUTE_WH"
database = "US_OPEN_CENSUS_DATA__NEIGHBORHOOD_INSIGHTS__FREE_DATASET"
schema = "PUBLIC"
